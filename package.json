{
  "name": "cia-admin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:home-icon": "node scripts/build-animated-icon.mjs src/assets/icons/home-animated.gif src/assets/icons/home-animated-transparent.gif",
    "build:company-icon": "node scripts/build-animated-icon.mjs src/assets/icons/company-animated.gif src/assets/icons/company-animated-transparent.gif",
    "build:employee-icon": "node scripts/build-animated-icon.mjs src/assets/icons/employee-animated.gif src/assets/icons/employee-animated-transparent.gif",
    "build:attendance-icon": "node scripts/build-animated-icon.mjs src/assets/icons/attendance-animated.gif src/assets/icons/attendance-animated-transparent.gif",
    "build:student-icon": "node scripts/build-animated-icon.mjs src/assets/icons/student-animated.gif src/assets/icons/student-animated-transparent.gif",
    "build:leave-icon": "node scripts/build-animated-icon.mjs src/assets/icons/leave-animated.gif src/assets/icons/leave-animated-transparent.gif",
    "build:user-icon": "node scripts/build-animated-icon.mjs src/assets/icons/user-animated.gif src/assets/icons/user-animated-transparent.gif",
    "build:icons": "npm run build:home-icon && npm run build:company-icon && npm run build:employee-icon && npm run build:attendance-icon && npm run build:student-icon && npm run build:leave-icon && npm run build:user-icon"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "daisyui": "^5.5.14",
    "jwt-decode": "^4.0.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.0",
    "react-router-dom": "^7.12.0",
    "recharts": "^3.9.2",
    "swr": "^2.3.8",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gifenc": "^1.0.3",
    "gifuct-js": "^2.1.2",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
